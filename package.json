{
  "name": "server",
  "version": "1.0.0",
  "description": "TAG Backend",
  "main": "server/dist/server.js",
  "scripts": {
    "start": "node server/dist/server.js",
    "dev": "nodemon server/src/server.ts",
    "build:client": "cd client && npm install && npm run build",
    "build:server": "tsc -p server/tsconfig.json",
    "build": "npm run build:client && npm run build:server"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pdfkit": "^0.15.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.5",
    "@types/pdfkit": "^0.13.5",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
